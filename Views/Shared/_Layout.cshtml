<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>LibrarySystem | Management</title>
    
   
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700&display=swap" rel="stylesheet">
    @* Bootstrap 5 *@
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    @* FontAwesome *@
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        body { font-family: 'Inter', sans-serif; background-color: #f8f9fa; color: #334155; }
        .navbar { border-bottom: 1px solid #e2e8f0; }
        .nav-link { font-weight: 500; color: #64748b !important; padding: 0.5rem 1rem !important; }
        .nav-link:hover { color: #0f172a !important; }
        .navbar-brand { font-weight: 700; letter-spacing: -0.5px; }
        .container-main { min-height: 80vh; padding-top: 2rem; }
        .footer { border-top: 1px solid #e2e8f0; background: white; }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-light bg-white py-3">
            <div class="container">
                <a class="navbar-brand text-primary" href="/">
                    <i class="fa-solid fa-book-quran me-2"></i>LibrarySystem
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav ms-auto">
                        <li class="nav-item">
                            <a class="nav-link" href="/Book/Index">
                                <i class="fa-solid fa-layer-group me-1"></i> Books
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/User/Index">
                                <i class="fa-solid fa-users me-1"></i> Users
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="/Loan/Index">
                                <i class="fa-solid fa-receipt me-1"></i> Loans
                            </a>
                        </li>
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container container-main">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="footer py-4 mt-5">
        <div class="container text-center">
            <p class="text-muted mb-0 small">&copy; 2026 - LibrarySystem Management Dashboard</p>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>