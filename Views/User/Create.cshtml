@* le avisamos a la vista que el formulario va a armar un objeto tipo User *@
@model LibrarySystem.Models.User

@{
    ViewData["Title"] = "New User";
}

<div class="container mt-4">
    <h2>Register a New User</h2>

    @* cuando le den submit, envia los datos por POST al UserController *@
    <form action="/User/Create" method="post" class="mt-4" style="max-width: 400px;">
        
        <div class="mb-3">
            <label class="form-label">Full Name</label>
            @* el name="FullName" debe ser identico a la propiedad en C# *@
            <input type="text" name="FullName" class="form-control" required autocomplete="off" />
        </div>

        <div class="mb-3">
            <label class="form-label">Email Address</label>
            <input type="email" name="Email" class="form-control" required autocomplete="off" />
        </div>

        @* no ponemos el input de multas (HasPenalties) porque por defecto entra en false *@

        <div class="mt-3">
            @* dispara el guardado *@
            <button type="submit" class="btn btn-success">Save User</button>
            @* boton para arrepentirse y volver a la tabla *@
            <a href="/User/Index" class="btn btn-secondary ms-2">Cancel</a>
        </div>
        
    </form>
</div>