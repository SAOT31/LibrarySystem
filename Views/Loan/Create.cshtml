
@{
    ViewData["Title"] = "New Loan";
}

<div class="container mt-4">
    <h2>Register a New Loan</h2>

    <form action="/Loan/Create" method="post" class="mt-4" style="max-width: 400px;">
        
        <div class="mb-3">
            <label class="form-label">Select User</label>
            <select name="userId" class="form-select" required>
                <option value="">-- Choose a user --</option>
                
                @* sacamos la lista de usuarios del ViewBag para armar las opciones *@
                @foreach (var user in ViewBag.Users)
                {
                    <option value="@user.Id">@user.FullName</option>
                }
            </select>
        </div>

        <div class="mb-3">
            <label class="form-label">Select Book</label>
            <select name="bookId" class="form-select" required>
                <option value="">-- Choose a book --</option>
                
                @* sacamos la lista de libros del ViewBag *@
                @foreach (var book in ViewBag.Books)
                {
                    <option value="@book.Id">@book.Title</option>
                }
            </select>
        </div>

        <div class="mt-3">
            @* dispara el guardado hacia el controller *@
            <button type="submit" class="btn btn-success">Register Loan</button>
            <a href="/Loan/Index" class="btn btn-secondary ms-2">Cancel</a>
        </div>
        
    </form>
</div>